# Default to LF line endings in the repository.
* text=auto eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf

# Images (binary)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary

# Fonts (binary)
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary

# Archives (binary)
*.zip binary
*.gz binary
*.7z binary